# =============================================================================
# Ubuntu Bootstrap Project - .gitignore
# =============================================================================
# This file prevents tracking of temporary files, user configurations,
# and system-generated content to keep the repository clean.

# User Configuration Files
# These files are generated during setup and contain user-specific settings
config.yml                      # Main user configuration (generated by wizard)
local-config.yml               # Local overrides
user-profiles/                 # User profile storage
.bootstrap-state              # Installation state tracking

# Ansible Generated Files
*.retry                        # Ansible retry files
*.log                         # Log files
.ansible/                     # Ansible working directory
ansible.log                   # Main Ansible log
.ansible_bootstrap_complete   # Bootstrap completion marker

# Vault and Security
*.vault                       # Encrypted vault files
vault-password.txt           # Vault password file
.vault-password              # Alternative vault password file
.ssh-keys/                   # Generated SSH keys
private-keys/                # Any private key storage

# Python Runtime Files
__pycache__/                 # Python cache directories
*.py[cod]                    # Python compiled files
*$py.class                   # Python class files
*.so                         # Shared object files
.Python                      # Python runtime files
*.egg-info/                  # Python package info
dist/                        # Distribution files
build/                       # Build artifacts

# Virtual Environments
env/                         # Virtual environment
venv/                        # Virtual environment
.venv/                       # Virtual environment
.env                         # Environment variables file
.envrc                       # direnv configuration

# IDE and Editor Files
.vscode/                     # VS Code settings
.idea/                       # IntelliJ/PyCharm settings
*.swp                        # Vim swap files
*.swo                        # Vim swap files
*~                          # Backup files
.netrwhist                  # Vim netrw history
tags                        # ctags files
.tags                       # ctags files

# Operating System Files
.DS_Store                   # macOS Finder settings
.DS_Store?                  # macOS Finder settings
._*                         # macOS resource forks
.Spotlight-V100            # macOS Spotlight
.Trashes                   # macOS Trash
ehthumbs.db                # Windows thumbnails
Thumbs.db                  # Windows thumbnails
Desktop.ini                # Windows desktop settings

# Testing and Development
.molecule/                  # Molecule test framework
.cache/                     # General cache directory
.pytest_cache/             # pytest cache
.tox/                      # tox testing
htmlcov/                   # HTML coverage reports
.coverage                  # Coverage data
.coverage.*                # Coverage data
coverage.xml               # Coverage XML report
*.cover                    # Coverage files
.hypothesis/               # Hypothesis testing
.mypy_cache/              # mypy type checker cache
.dmypy.json               # dmypy daemon
dmypy.json                # dmypy daemon

# Temporary and Backup Files
*.tmp                      # Temporary files
*.temp                     # Temporary files
*.bak                      # Backup files
*.backup                   # Backup files
*.orig                     # Original files
.tmp/                      # Temporary directory
tmp/                       # Temporary directory
*-backup                   # Backup files
*-old                      # Old files

# Application-Specific Temporary Files
/tmp/                      # Temporary files created by scripts
*.pid                      # Process ID files
*.sock                     # Socket files
*.lock                     # Lock files
.sudo_as_admin_successful  # Ubuntu sudo marker

# Package Manager Files
node_modules/              # Node.js packages
.npm/                      # npm cache
.yarn/                     # Yarn cache
.pnpm-store/              # pnpm store
Pipfile.lock              # Python pipenv lock
poetry.lock               # Python poetry lock
.bundle/                   # Ruby bundle
vendor/                    # Vendor packages

# Generated Documentation
docs/_build/               # Sphinx documentation
docs/build/               # Documentation build
.readthedocs.yml          # ReadTheDocs config (if auto-generated)
site/                     # MkDocs site

# CI/CD and Deployment
.github/workflows/        # GitHub Actions (if auto-generated)
.gitlab-ci.yml           # GitLab CI (if auto-generated)
.travis.yml              # Travis CI (if auto-generated)
.circleci/               # CircleCI (if auto-generated)
.jenkins/                # Jenkins (if auto-generated)
deployment/              # Deployment artifacts
*.deb                    # Debian packages
*.rpm                    # RPM packages
*.snap                   # Snap packages

# Security Scanner Results
.snyk                    # Snyk security scanner
bandit.json             # Bandit security scanner
safety-report.json      # Safety security scanner
audit-results.json      # Security audit results

# Logs and Monitoring
logs/                   # Log directory
*.log.*                 # Rotated log files
audit.log              # Audit logs
error.log              # Error logs
access.log             # Access logs
debug.log              # Debug logs

# Database Files
*.db                   # Database files
*.sqlite               # SQLite databases
*.sqlite3              # SQLite3 databases
data/                  # Data directory

# Custom/Project-Specific Ignores
# Add any project-specific files that should not be tracked
.bootstrap-debug       # Debug mode marker
maintenance-mode       # Maintenance mode marker
custom-scripts/        # User custom scripts
local-roles/          # Local Ansible roles
local-vars/           # Local variable files